# BNB Testnet RPC (default for v0)
# 推荐使用 publicnode；部分官方 prebsc 节点虽然能响应 curl，
# 但在 ethers v6 的默认网络探测阶段可能超时，真实合约读调用也可能 ECONNRESET。
RPC_URL=https://bsc-testnet.publicnode.com
CHAIN_ID=97

# 如需使用官方 prebsc 节点，可改为：
# RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# BNB Mainnet (optional, requires API key)
# RPC_URL=https://bsc-dataseed.binance.org/
# CHAIN_ID=56

# Predict.fun API
API_BASE_URL=https://api-testnet.predict.fun
# API_BASE_URL=https://api.predict.fun  # 主网需要 x-api-key header
# API_KEY=your-api-key-here
